# Frontend Environment Variables
# Copy this file to .env.local and update the values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:1270/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:8100

# Stripe (publishable key — safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# TinyMCE API Key for Rich Text Editor
# Get your free API key from: https://www.tiny.cloud/auth/signup/
NEXT_PUBLIC_TINY_API_KEY=your_tiny_api_key_here

# Authentication (if needed)
NEXT_PUBLIC_AUTH_ENABLED=false

# Feature Flags
NEXT_PUBLIC_AI_EVALUATION_ENABLED=true
NEXT_PUBLIC_SHOPIFY_INTEGRATION_ENABLED=true
NEXT_PUBLIC_ALERT_SYSTEM_ENABLED=true

# UI Configuration
NEXT_PUBLIC_THEME=dark
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_ITEMS_PER_PAGE=50

# Development
NEXT_PUBLIC_DEBUG_MODE=true
